<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvPreviewTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Media Preview"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:layout_marginBottom="8dp"/>

        <ImageView
            android:id="@+id/ivThumbnail"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:background="#EEE"
            android:layout_marginBottom="12dp"
            android:contentDescription="Thumbnail" />

        <TextView
            android:id="@+id/tvMediaInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Type: Video | Duration: 0:00"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quality"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <RadioGroup
            android:id="@+id/rgQuality"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <RadioButton
                android:id="@+id/rbBest"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Best"
                android:checked="true"/>
            <RadioButton
                android:id="@+id/rbMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="720p"/>
            <RadioButton
                android:id="@+id/rbWorst"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Smallest"/>
        </RadioGroup>

        <LinearLayout
            android:id="@+id/layoutCarouselOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="16dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Carousel Options"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <CheckBox
                android:id="@+id/cbOnlyFirstItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Download only first item"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Additional Options"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <CheckBox
            android:id="@+id/cbIncludeCaption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Include Caption"
            android:checked="true"
            android:layout_marginBottom="4dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilCaption"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Edit Caption"
            android:layout_marginBottom="16dp"
            app:counterEnabled="true"
            app:counterMaxLength="1000">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCaption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:minLines="3" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Content Types"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/cgFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:chipSpacingHorizontal="8dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipVideo"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Video"
                android:checked="true"
                app:chipIcon="@android:drawable/presence_video_online"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPhoto"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Photos"
                android:checked="true"
                app:chipIcon="@android:drawable/ic_menu_gallery"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAudio"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Audio"
                android:checked="true"
                app:chipIcon="@android:drawable/ic_lock_silent_mode"/>

        </com.google.android.material.chip.ChipGroup>

        <CheckBox
            android:id="@+id/cbSaveDefault"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save these as default for manual links"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShowAdvanced"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Advanced Download Tools ▼"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/layoutAdvanced"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="8dp"
            android:background="#0A000000"
            android:layout_marginBottom="16dp">

            <CheckBox
                android:id="@+id/cbAudioOnly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Extract Audio Only (MP3)"/>

            <CheckBox
                android:id="@+id/cbWriteSubs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Download &amp; Embed Subtitles"/>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Custom yt-dlp Args (e.g. --max-filesize 50M)">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCustomArgs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmDownload"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="START DOWNLOAD" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
