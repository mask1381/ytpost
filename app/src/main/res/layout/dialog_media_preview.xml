<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvPreviewTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Media Preview"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:layout_marginBottom="8dp"/>

        <ImageView
            android:id="@+id/ivThumbnail"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:background="#EEE"
            android:layout_marginBottom="12dp"
            android:contentDescription="Thumbnail" />

        <TextView
            android:id="@+id/tvMediaInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Type: Video | Duration: 0:00"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quality"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <RadioGroup
            android:id="@+id/rgQuality"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <RadioButton
                android:id="@+id/rbBest"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Best"
                android:checked="true"/>
            <RadioButton
                android:id="@+id/rbMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="720p"/>
            <RadioButton
                android:id="@+id/rbWorst"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Smallest"/>
        </RadioGroup>

        <LinearLayout
            android:id="@+id/layoutCarouselOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="16dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Carousel Options"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <CheckBox
                android:id="@+id/cbOnlyFirstItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Download only first item"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filter Content Type"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <CheckBox
                android:id="@+id/cbVideo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Video"
                android:checked="true"/>
            <CheckBox
                android:id="@+id/cbPhoto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Photo"
                android:checked="true"/>
            <CheckBox
                android:id="@+id/cbAudio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Audio"
                android:checked="true"/>
        </LinearLayout>

        <CheckBox
            android:id="@+id/cbSaveDefault"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save these as default for manual links"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmDownload"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="START DOWNLOAD" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
