<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/navigation_post">

    <fragment
        android:id="@+id/navigation_post"
        android:name="com.example.ytpost.ui.PostFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_post" />

    <fragment
        android:id="@+id/navigation_tasks"
        android:name="com.example.ytpost.ui.TasksFragment"
        android:label="Queue &amp; History"
        tools:layout="@layout/fragment_tasks" />

    <fragment
        android:id="@+id/navigation_rss"
        android:name="com.example.ytpost.ui.RssManagerFragment"
        android:label="Automation"
        tools:layout="@layout/fragment_rss_manager" />

    <fragment
        android:id="@+id/navigation_settings"
        android:name="com.example.ytpost.ui.SettingsFragment"
        android:label="Configuration"
        tools:layout="@layout/fragment_settings" />
</navigation>
